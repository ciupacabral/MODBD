---
title: Diagrama Entitate-Relatie OLTP (notatie Chen, linii ortogonale)
config:
  flowchart:
    curve: step
    htmlLabels: true
---
flowchart TB

  %% === ENTITATI (dreptunghiuri) ===
  ZONE[ZONE]
  AGENTI[AGENTI]
  CLIENTI[CLIENTI]
  CC[CLIENTI_CONTACTE]
  IP[INTERVALE_PLATA]
  IPZ[/"INTERVALE_PLATA_ZILE<br/>(entitate slaba)"/]
  FISE[FISE_CLIENTI]
  ITEMS[MS_ITEMS]
  BRANDS[BRANDS]
  CAT[ITEMS_CATEGORY]
  TYPE[ITEMS_TYPE]
  SEZ[ITEMS_SEASONS]

  %% === RELATII (romburi) ===
  R_DES{deserveste}
  R_IER{ierarhie}
  R_ACO{acopera}
  R_APL{aplica}
  R_DET{detaliaza}
  R_CON{are contact}
  R_EMI{emite}
  R_CTN{contine}
  R_PRO{produce}
  R_CLA{clasifica}
  R_TIP{categoriseaza}
  R_SEZ{apartine la}

  %% === Legaturi cu cardinalitati (12 relatii x 2 linii = 24 linkStyle) ===
  ZONE ---|"1"| R_DES
  R_DES ---|"N"| CLIENTI

  ZONE ---|"N"| R_IER
  R_IER ---|"1"| ZONE

  ZONE ---|"M"| R_ACO
  R_ACO ---|"N"| AGENTI

  ZONE ---|"M"| R_APL
  R_APL ---|"N"| IP

  IP ---|"1"| R_DET
  R_DET ---|"N"| IPZ

  CLIENTI ---|"1"| R_CON
  R_CON ---|"0..1"| CC

  CLIENTI ---|"1"| R_EMI
  R_EMI ---|"N"| FISE

  FISE ---|"M"| R_CTN
  R_CTN ---|"N"| ITEMS

  BRANDS ---|"1"| R_PRO
  R_PRO ---|"N"| ITEMS

  CAT ---|"1"| R_CLA
  R_CLA ---|"N"| ITEMS

  TYPE ---|"1"| R_TIP
  R_TIP ---|"N"| ITEMS

  SEZ ---|"1"| R_SEZ
  R_SEZ ---|"N"| ITEMS

  %% === Culori distincte pentru fiecare relatie (perechi de 2 linii) ===
  linkStyle 0,1   stroke:#1565c0,stroke-width:2px
  linkStyle 2,3   stroke:#6a1b9a,stroke-width:2px
  linkStyle 4,5   stroke:#c62828,stroke-width:2px
  linkStyle 6,7   stroke:#2e7d32,stroke-width:2px
  linkStyle 8,9   stroke:#ef6c00,stroke-width:2px
  linkStyle 10,11 stroke:#00838f,stroke-width:2px
  linkStyle 12,13 stroke:#5d4037,stroke-width:2px
  linkStyle 14,15 stroke:#7b1fa2,stroke-width:2px
  linkStyle 16,17 stroke:#0277bd,stroke-width:2px
  linkStyle 18,19 stroke:#558b2f,stroke-width:2px
  linkStyle 20,21 stroke:#d84315,stroke-width:2px
  linkStyle 22,23 stroke:#283593,stroke-width:2px

  %% === Styling entitati / relatii ===
  classDef entitate fill:#e3f2fd,stroke:#1565c0,stroke-width:2px,color:#000,font-weight:bold
  classDef entitateSlaba fill:#f3e5f5,stroke:#6a1b9a,stroke-width:2px,color:#000,font-weight:bold
  classDef relatie fill:#fff3e0,stroke:#e65100,stroke-width:2px,color:#000

  class ZONE,AGENTI,CLIENTI,CC,IP,FISE,ITEMS,BRANDS,CAT,TYPE,SEZ entitate
  class IPZ entitateSlaba
  class R_DES,R_IER,R_ACO,R_APL,R_DET,R_CON,R_EMI,R_CTN,R_PRO,R_CLA,R_TIP,R_SEZ relatie
